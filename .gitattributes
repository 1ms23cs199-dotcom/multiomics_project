# Git LFS tracking rules
# Files tracked here are stored in GitHub LFS instead of regular git
# This avoids the 100MB GitHub file size limit for large data files
# Updated March 18, 2026 - Track ALL processed CSVs to fix cloning issues

# ====== PROCESSED DATA (Phase 2–3 outputs) ======
# ALL CSV files in processed (genomic, proteomic, environmental, integrated)
# Includes: feature engineering outputs, final datasets, train/test splits
data/processed/**/*.csv filter=lfs diff=lfs merge=lfs -text

# ====== RAW GENOMIC DATA ======
# GEO series matrix files (compressed) — some exceed 100MB
data/raw/genomic/*.gz filter=lfs diff=lfs merge=lfs -text
# FASTA genome sequence
data/raw/genomic/*.fasta filter=lfs diff=lfs merge=lfs -text

# ====== RAW PROTEOMICS DATA ======
# UniProt FASTA
data/raw/proteomic/*.fasta filter=lfs diff=lfs merge=lfs -text

# ====== FUTURE: MODEL WEIGHTS & CHECKPOINTS ======
# For Phase 4+ models (Transformer, Quantum circuits, etc.)
models/**/*.pt filter=lfs diff=lfs merge=lfs -text
models/**/*.pth filter=lfs diff=lfs merge=lfs -text
models/**/*.pkl filter=lfs diff=lfs merge=lfs -text
models/**/*.ckpt filter=lfs diff=lfs merge=lfs -text
models/**/*.h5 filter=lfs diff=lfs merge=lfs -text
