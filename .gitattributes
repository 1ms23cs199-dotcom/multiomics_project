# Git LFS tracking rules
# Files tracked here are stored in GitHub LFS instead of regular git
# This avoids the 100MB GitHub file size limit for large genomic files
# GEO series matrix files (compressed) — some exceed 100MB
data/raw/genomic/*.gz filter=lfs diff=lfs merge=lfs -text
# GPL6947 annotation (108 MB compressed)
data/raw/genomic/GPL6947_family.soft.gz filter=lfs diff=lfs merge=lfs -text
# FASTA genome sequence
data/raw/genomic/*.fasta filter=lfs diff=lfs merge=lfs -text
# UniProt FASTA
data/raw/proteomic/*.fasta filter=lfs diff=lfs merge=lfs -text
data/processed/genomic/*.csv filter=lfs diff=lfs merge=lfs -text
